# --- Project Configuration ---
PROJECT_NAME="PID_WGS_Analysis"
AUTHOR="Dr. Rafal Urniaz"

# --- Filtering Thresholds ---
EX_AF=0.01   # gnomAD Allele Frequency
EX_MAF=0.05  # Minor Allele Frequency

# --- HPC Paths (Update these for your environment) ---
INPUT_DIR="/path/to/raw/vcfs"
OUTPUT_DIR="./results"
SAMPLE_FILE="./metadata/cohort_samples.sample"
EXCLUDE_LIST="./metadata/exclude_list.sample"

# --- Software ---
SNPTEST_BIN="snptest" # Assumes snptest is in $PATH